# Copy to .env (git-ignored), fill in values from your Apple developer
# account, then run `direnv allow`. On the first release, the script stores
# the app-specific password in the PaceNotary Keychain profile.
APPLE_ID=you@example.com
APPLE_ID_PASSWORD=abcd-efgh-ijkl-mnop
TEAM_ID=ABCDE12345

# Optional when the script can discover the identity for TEAM_ID.
# DEVELOPER_ID_APPLICATION="Developer ID Application: Example Company (ABCDE12345)"

# These are the defaults; set them explicitly to make the release environment
# self-documenting.
NOTARY_PROFILE=PaceNotary
GH_REPO=owner/Pace
