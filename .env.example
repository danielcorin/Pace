# Copy to .env (git-ignored) for a non-interactive notarized release.
# Loaded automatically via .envrc when direnv is installed.

# Option A: Apple ID + app-specific password (created at appleid.apple.com).
APPLE_ID=you@example.com
APPLE_ID_PASSWORD=abcd-efgh-ijkl-mnop
TEAM_ID=ABCDE12345

# Option B (preferred): a Keychain notary profile, set up once with
#   scripts/publish-release.sh --setup-notary-profile PaceNotary
# NOTARY_PROFILE=PaceNotary

# Optional: target repo for `--publish` (defaults to the origin remote).
# GH_REPO=owner/Pace
